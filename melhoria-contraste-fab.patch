From: Claude <assistant@claude.local>
Date: Wed, 8 Jul 2026 03:12:37 +0000
Subject: [PATCH] =?UTF-8?q?Aumenta=20contraste=20dos=20cards=20no=20tema?=
 =?UTF-8?q?=20claro=20mobile=20e=20evita=20FAB=20sobrepor=20conte=C3=BAdo?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- bg e card estavam quase na mesma cor (#f7f8f4 vs #ffffff) com sombra de 8% de opacidade, fazendo os cards se fundirem com o fundo da tela
- aumenta a diferença de tom entre bg/card e reforça a sombra (--shadow-soft) para dar profundidade real
- aumenta o padding inferior do scroller para o botão flutuante (+) não sobrepor o gráfico/ações da última transação
---
 css/main.css | 14 +++++++-------
 1 file changed, 7 insertions(+), 7 deletions(-)

diff --git a/css/main.css b/css/main.css
index 99f9049..bbd5d03 100644
--- a/css/main.css
+++ b/css/main.css
@@ -156,7 +156,7 @@ body.logged-out #desktop-app{display:none!important}
 .m-mini{border-radius:18px;padding:14px 14px}
 .m-mini .val,.d-mini .val{font-size:22px;font-weight:900;letter-spacing:-.04em}
 
-.m-scroller{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:12px 14px calc(env(safe-area-inset-bottom,0px) + 82px)}
+.m-scroller{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:12px 14px calc(env(safe-area-inset-bottom,0px) + 148px)}
 .m-scroller::-webkit-scrollbar{display:none}
 .m-page{display:none}.m-page.active{display:block}
 
@@ -1707,14 +1707,14 @@ body.logged-out .d-main {
    ═══════════════════════════════════════════════════════════════════════════ */
 @media (max-width: 767px) {
   [data-theme="light"] {
-    --bg:#f7f8f4;
+    --bg:#eef1ea;
     --bg2:#ffffff;
-    --bg3:#eef4ee;
+    --bg3:#e7ede6;
     --card:#ffffff;
     --card2:#f4f7f3;
     --surface:#ffffff;
-    --border:rgba(20,35,27,.08);
-    --border2:rgba(22,163,74,.18);
+    --border:rgba(20,35,27,.10);
+    --border2:rgba(22,163,74,.22);
     --text:#1f2420;
     --text2:rgba(31,36,32,.64);
     --text3:rgba(31,36,32,.42);
@@ -1725,8 +1725,8 @@ body.logged-out .d-main {
     --green-bg:rgba(22,184,95,.10);
     --red:#e9414d;
     --red-bg:rgba(233,65,77,.10);
-    --shadow:0 18px 48px rgba(27,40,31,.12);
-    --shadow-soft:0 8px 24px rgba(27,40,31,.08);
+    --shadow:0 18px 48px rgba(27,40,31,.16);
+    --shadow-soft:0 10px 28px rgba(27,40,31,.13);
   }
 
   #mobile-app {
-- 
